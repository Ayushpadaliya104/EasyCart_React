# EasyCart Environment Configuration (Example)
# Copy this file to .env and fill in your values

# React App Configuration
REACT_APP_NAME=EasyCart
REACT_APP_VERSION=1.0.0

# API Configuration (for future backend integration)
REACT_APP_API_URL=http://localhost:5000
REACT_APP_API_TIMEOUT=30000

# Authentication
REACT_APP_AUTH_TOKEN_KEY=easycart_auth_token
REACT_APP_REMEMBER_ME_KEY=easycart_remember_me

# Third-party Services
REACT_APP_STRIPE_PUBLIC_KEY=your_stripe_public_key_here
REACT_APP_PAYPAL_CLIENT_ID=your_paypal_client_id_here
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id_here

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_SOCIAL_LOGIN=true
REACT_APP_ENABLE_ORDER_TRACKING=true

# Development
SKIP_PREFLIGHT_CHECK=true
FAST_REFRESH=true
